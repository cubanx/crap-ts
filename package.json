{
	"name": "crap-ts",
	"version": "0.1.1",
	"description": "Small CRAP-score audit helper for TypeScript projects.",
	"type": "module",
	"bin": {
		"crap-ts": "src/cli.js"
	},
	"exports": {
		".": {
			"types": "./src/index.d.ts",
			"default": "./src/index.js"
		},
		"./crap-analysis": {
			"types": "./src/crap-analysis.d.ts",
			"default": "./src/crap-analysis.js"
		},
		"./crap-runner": {
			"types": "./src/crap-runner.d.ts",
			"default": "./src/crap-runner.js"
		},
		"./crap-score": {
			"types": "./src/crap-score.d.ts",
			"default": "./src/crap-score.js"
		}
	},
	"files": [
		"src",
		"README.md",
		"CONTRIBUTING.md",
		"LICENSE"
	],
	"scripts": {
		"check": "node --check src/cli.js && node --check src/crap-analysis.js && node --check src/crap-runner.js && node --check src/crap-score.js",
		"score": "node src/cli.js score --metrics fixtures/complexity-metrics.json --coverage-file fixtures/coverage-summary.json --max-crap 30",
		"test": "node --test tests/*.test.js",
		"test:consumer-typescript": "node scripts/verify-consumer-typescript.mjs",
		"validate": "npm run test && npm run score",
		"lint": "biome ci .",
		"format": "biome check --write ."
	},
	"keywords": [
		"complexity",
		"typescript",
		"quality"
	],
	"license": "MIT",
	"engines": {
		"node": ">=20"
	},
	"peerDependencies": {
		"typescript": ">=5.9 <8"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"typescript": "^5.9.3"
	}
}
